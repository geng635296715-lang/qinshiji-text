{
  "name": "qinshiji-text",
  "version": "0.1.0",
  "description": "Qinshiji backend first draft for divination, bazi, AI consultation, and personalized advice.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --enable-source-maps dist/server.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "sync:frontend": "node scripts/sync-qing-shiji-frontend.mjs",
    "video:studio": "remotion studio src/remotion/index.ts",
    "video:render": "remotion render src/remotion/index.ts QingShijiLoop dist/qing-shiji-loop-raw.mp4 --timeout=240000 && remotion ffmpeg -y -i dist/qing-shiji-loop-raw.mp4 -an -c:v copy dist/qing-shiji-loop.mp4"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@remotion/cli": "^4.0.486",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.1",
    "fastify": "^5.6.0",
    "lunar-typescript": "^1.8.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "^4.0.486",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
